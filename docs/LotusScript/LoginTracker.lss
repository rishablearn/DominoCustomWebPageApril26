'===========================================================================
' LoginTracker.lss
' LotusScript Agent — Log Login Attempts to Person Document in NAMES.NSF
'
' Version  : 1.1.0
' Date     : 2026-06-25
' Requires : HCL Domino 12.0.1+
'
' PURPOSE
' -------
' Receives a web POST from the custom login page, reads the client-supplied
' browser fingerprint plus the server-side IP address, then prepends a new
' entry to the LoginHistory multi-value field on the matching Person document
' in NAMES.NSF, retaining the last MAX_HISTORY entries.
'
' FIELD FORMAT (pipe-delimited per entry)
' ----------------------------------------
'   TIMESTAMP|IP|STATUS|BROWSER|PLATFORM|TIMEZONE|SCREEN|MFA
'
'   Example:
'   2026-06-25T07:30:00Z|192.168.1.10|ATTEMPT|Chrome|Win10|Asia/Kolkata|1920x1080|0
'
'   Field positions:
'     0 = ISO 8601 timestamp (UTC)
'     1 = Client IP address (from REMOTE_ADDR / X-Forwarded-For)
'     2 = Status: ATTEMPT (always; server cannot confirm success/failure)
'     3 = Browser name  (Chrome, Firefox, Edge, Safari, Opera)
'     4 = Platform/OS   (Windows, macOS, Linux, Android, etc.)
'     5 = Timezone      (IANA format, e.g. Asia/Kolkata)
'     6 = Screen size   (e.g. 1920x1080)
'     7 = MFA used      (1 = yes, 0 = no)
'
' =========================================================================
' PREREQUISITES — complete ALL steps before enabling in login page config
' =========================================================================
'
' A. PERSON DOCUMENT FIELD PROVISIONING
'    ------------------------------------
'    The agent writes two fields directly to the Person document:
'      LoginHistory         (Multi-value Text)  — last N login entries
'      LoginHistoryUpdated  (Date/Time)         — timestamp of last update
'
'    No schema change is required — Domino allows arbitrary fields on
'    existing documents.  The fields are created automatically on first run.
'
'    OPTIONAL — to make LoginHistory visible in Domino Administrator UI:
'      1. Open pubnames.ntf in Domino Designer
'      2. Open the "Person" form → subform "($PersonBasicInfo)" or similar
'      3. Add a multi-value Text field named exactly "LoginHistory"
'      4. Add a DateTime field named "LoginHistoryUpdated"
'      5. Save, sign, and replace the design of names.nsf with pubnames.ntf
'      NOTE: This step is cosmetic only and NOT required for tracking to work.
'
' B. EMAIL NOTIFICATION PREREQUISITES (ONLY if SEND_EMAIL_ON_NEW_ATTEMPT = True)
'    -------------------------------------------------------------------------
'    Notification emails use the standard Domino Memo form.
'    NO changes to the mail template (mail12.ntf or equivalent) are required.
'    The mail template is completely unrelated to login history storage.
'    Prerequisites for email alerts only:
'      - Domino mail router must be running on the server
'      - The Person document must have a valid InternetAddress or FullName
'      - The signing ID must have sufficient rights to send mail on this server
'
' =========================================================================
' DEPLOYMENT CHECKLIST
' =========================================================================
'
' Step 1 — Create the Agent
'   [ ] Open DOMCFG.NSF in Domino Designer
'   [ ] Shared Code → Agents → New Agent
'         Name                              : LogLoginAttempt
'         Language                          : LotusScript
'         When should this agent run        : On Event
'         Which document(s) should it act on: None
'         Run as web user                   : UNCHECKED
'           (agent must run as signer; login POST arrives as Anonymous —
'            if checked the agent would have no write access to names.nsf)
'   [ ] Paste the entire contents of this file into the Script area
'   [ ] Save the agent (do NOT sign yet)
'
' Step 2 — Configure Constants (top of Initialize sub)
'   [ ] NAMES_SERVER  — "" for current server, or "ServerName/Org" for remote
'   [ ] NAMES_DB_PATH — "names.nsf" (default; change if your directory differs)
'   [ ] MAX_HISTORY   — number of past entries to keep per user (default: 5)
'   [ ] SEND_EMAIL_ON_NEW_ATTEMPT — False (default); set True to send email alerts
'
' Step 3 — Sign the Agent
'   [ ] In Domino Designer: select the agent → File → Sign
'         Sign with an ID that has:
'           - Editor or Author access on NAMES.NSF  (to write LoginHistory)
'           - Reader access on DOMCFG.NSF           (to run as web user)
'   [ ] Confirm the signer appears in the agent properties
'
' Step 4 — Set Database ACL
'   [ ] DOMCFG.NSF ACL:
'         Anonymous    : Reader      (minimum — required for web POST)
'         LocalDomainServers : Manager
'   [ ] NAMES.NSF ACL:
'         The signing ID must have Author or Editor access
'         (standard Domino Directory ACL usually grants this to server IDs)
'
' Step 5 — Server Security Settings
'   [ ] Domino Administrator → Configuration → Server → Security tab
'         "Run restricted LotusScript/Java agents"  — add the signing ID
'         OR
'         "Run unrestricted LotusScript/Java agents" — add the signing ID
'         (this agent uses only basic Notes classes; restricted is sufficient)
'
' Step 6 — Verify the Agent
'   [ ] Browse to: https://yourserver/domcfg.nsf/LogLoginAttempt?OpenAgent
'         Expected response body: OK
'         (username param is empty so agent exits early but returns OK)
'   [ ] Submit the login page once with a real username
'   [ ] Check Person document in Domino Administrator — LoginHistory should
'       have one new entry
'
' Step 7 — Enable in Login Page Config
'   [ ] In EnterpriseLoginForm.html or DominoEmbeddedForm.html:
'         loginTracking: { enable: true, agentUrl: "/domcfg.nsf/LogLoginAttempt?OpenAgent" }
'   [ ] Reload the login page — the banner should appear immediately
'       (first load shows "Tracking Active" placeholder; after first submit
'        it shows the actual last attempt details)
'
' =========================================================================
' EMAIL NOTIFICATION (optional — disabled by default)
' =========================================================================
'   Set SEND_EMAIL_ON_NEW_ATTEMPT = True below.
'   The agent sends a plain-text memo to the user on every new attempt.
'   Requires: Domino mail router running + valid recipient address on Person doc.
'
'===========================================================================
Option Public
Option Declare

'--- CONFIGURATION -----------------------------------------------------------
Const MAX_HISTORY     = 5     ' Number of attempts to keep per user
Const NAMES_SERVER    = ""    ' "" = current server; or "ServerName/Org"
Const NAMES_DB_PATH   = "names.nsf"
Const SEND_EMAIL_ON_NEW_ATTEMPT = False
Const EMAIL_SUBJECT   = "Login Attempt Notification"

' DEBUG_MODE = True  → response body contains full trace of every step.
'              False → response is "OK" only (production setting).
' Set to True to diagnose lookup / save failures, then flip back to False.
Const DEBUG_MODE = True
'-----------------------------------------------------------------------------

Sub Initialize()
    Dim session  As New NotesSession
    Dim web      As NotesDocument     ' CGI + POST fields from HTTP context
    Dim dbg      As String            ' accumulated debug log

    On Error GoTo ErrorHandler

    Set web = session.DocumentContext

    '-- 1. Read POST parameters sent by the login page ----------------------
    Dim ts        As String  : ts       = GetField(web, "ts")
    Dim tz        As String  : tz       = GetField(web, "tz")
    Dim lang      As String  : lang     = GetField(web, "lang")
    Dim scr       As String  : scr      = GetField(web, "scr")
    Dim browser   As String  : browser  = GetField(web, "browser")
    Dim platform  As String  : platform = GetField(web, "platform")
    Dim mfa       As String  : mfa      = GetField(web, "mfa")
    Dim username  As String  : username = GetField(web, "username")
    Dim status    As String  : status   = "ATTEMPT"

    '-- 2. Retrieve real IP -------------------------------------------------
    Dim ipAddress As String
    ipAddress = GetField(web, "REMOTE_ADDR")
    If ipAddress = "" Then ipAddress = GetField(web, "HTTP_X_FORWARDED_FOR")
    If ipAddress = "" Then ipAddress = "unknown"

    '-- DEBUG: dump everything received ------------------------------------
    If DEBUG_MODE Then
        dbg = dbg & "=== LogLoginAttempt DEBUG ===" & Chr(10)
        dbg = dbg & "Server time : " & Now() & Chr(10)
        dbg = dbg & "username    : [" & username   & "]" & Chr(10)
        dbg = dbg & "ts          : [" & ts         & "]" & Chr(10)
        dbg = dbg & "browser     : [" & browser    & "]" & Chr(10)
        dbg = dbg & "platform    : [" & platform   & "]" & Chr(10)
        dbg = dbg & "tz          : [" & tz         & "]" & Chr(10)
        dbg = dbg & "scr         : [" & scr        & "]" & Chr(10)
        dbg = dbg & "mfa         : [" & mfa        & "]" & Chr(10)
        dbg = dbg & "lang        : [" & lang       & "]" & Chr(10)
        dbg = dbg & "REMOTE_ADDR : [" & ipAddress  & "]" & Chr(10)
        dbg = dbg & "---" & Chr(10)
    End If

    '-- 3. Validate we have a username --------------------------------------
    If username = "" Then
        If DEBUG_MODE Then
            dbg = dbg & "EXIT: username field is empty — nothing to record." & Chr(10)
            Call RespondDebug(dbg)
        Else
            Call RespondOk()
        End If
        Exit Sub
    End If

    '-- 4. Build the history entry string -----------------------------------
    Dim entry As String
    entry = ts & "|" & ipAddress & "|" & status & "|" & _
            browser & "|" & platform & "|" & tz & "|" & scr & "|" & mfa

    If DEBUG_MODE Then dbg = dbg & "Entry       : " & entry & Chr(10) & "---" & Chr(10)

    '-- 5. Open NAMES.NSF --------------------------------------------------
    Dim namesDb As NotesDatabase
    Set namesDb = New NotesDatabase(NAMES_SERVER, NAMES_DB_PATH)
    If Not namesDb.IsOpen Then Call namesDb.Open(NAMES_SERVER, NAMES_DB_PATH)

    If Not namesDb.IsOpen Then
        Call RespondError("Could not open " & NAMES_DB_PATH & " on server [" & NAMES_SERVER & "]", dbg)
        Exit Sub
    End If

    If DEBUG_MODE Then dbg = dbg & "names.nsf   : opened OK (server=[" & NAMES_SERVER & "])" & Chr(10)

    '-- 6. Find Person document — try multiple strategies ------------------
    Dim personDoc As NotesDocument
    Dim lookupLog As String

    ' Strategy A: ($Users) view — sorted by all FullName values.
    '   Works for canonical (CN=.../O=...) or abbreviated names.
    '   Usually does NOT match short names like "john.doe" directly.
    Dim usersView As NotesView
    Set usersView = namesDb.GetView("($Users)")
    If Not (usersView Is Nothing) Then
        Set personDoc = usersView.GetDocumentByKey(username, True)   ' exact
        lookupLog = lookupLog & "  ($Users) exact=[" & (Not personDoc Is Nothing) & "]"
        If personDoc Is Nothing Then
            Set personDoc = usersView.GetDocumentByKey(username, False)  ' partial
            lookupLog = lookupLog & " partial=[" & (Not personDoc Is Nothing) & "]"
        End If
    Else
        lookupLog = lookupLog & "  ($Users) view not found"
    End If

    ' Strategy B: ($VIMPeople) — sorted by FullName; try as internet address
    If personDoc Is Nothing Then
        Dim vimView As NotesView
        Set vimView = namesDb.GetView("($VIMPeople)")
        If Not (vimView Is Nothing) Then
            Set personDoc = vimView.GetDocumentByKey(username, True)
            lookupLog = lookupLog & Chr(10) & "  ($VIMPeople) exact=[" & (Not personDoc Is Nothing) & "]"
            If personDoc Is Nothing Then
                Set personDoc = vimView.GetDocumentByKey(username, False)
                lookupLog = lookupLog & " partial=[" & (Not personDoc Is Nothing) & "]"
            End If
            If Not (vimView Is Nothing) Then Call vimView.Recycle()
        Else
            lookupLog = lookupLog & Chr(10) & "  ($VIMPeople) view not found"
        End If
    End If

    ' Strategy C: Scan all Person documents comparing ShortName and
    '   InternetAddress (case-insensitive).  Slower but works when view
    '   sort keys don't match the typed username format.
    If personDoc Is Nothing Then
        lookupLog = lookupLog & Chr(10) & "  Scanning Person docs by ShortName / InternetAddress..."
        Dim scanCollection As NotesDocumentCollection
        Set scanCollection = namesDb.Search({Form = "Person"}, Nothing, 0)
        lookupLog = lookupLog & " count=" & scanCollection.Count
        Dim scanDoc As NotesDocument
        Set scanDoc = scanCollection.GetFirstDocument()
        Dim lowerUser As String
        lowerUser = LCase(Trim(username))
        Do While Not (scanDoc Is Nothing)
            Dim sn As String : sn = LCase(Trim(CStr(scanDoc.GetItemValue("ShortName")(0))))
            Dim ia As String : ia = LCase(Trim(CStr(scanDoc.GetItemValue("InternetAddress")(0))))
            Dim fn As String : fn = LCase(Trim(CStr(scanDoc.GetItemValue("FullName")(0))))
            If sn = lowerUser Or ia = lowerUser Or fn = lowerUser Then
                Set personDoc = scanDoc
                lookupLog = lookupLog & " MATCHED(ShortName=[" & sn & "] inet=[" & ia & "])"
                Exit Do
            End If
            Set scanDoc = scanCollection.GetNextDocument(scanDoc)
        Loop
        If personDoc Is Nothing Then lookupLog = lookupLog & " NO MATCH"
    End If

    If DEBUG_MODE Then
        dbg = dbg & "Lookup results:" & Chr(10) & lookupLog & Chr(10) & "---" & Chr(10)
    End If

    If personDoc Is Nothing Then
        If DEBUG_MODE Then
            dbg = dbg & "EXIT: Person document not found for username=[" & username & "]." & Chr(10)
            dbg = dbg & "      Check that the user exists in names.nsf and that the" & Chr(10)
            dbg = dbg & "      typed username matches ShortName or InternetAddress." & Chr(10)
            Call RespondDebug(dbg)
        Else
            Call RespondOk()   ' Do not leak user existence in production
        End If
        Exit Sub
    End If

    If DEBUG_MODE Then
        dbg = dbg & "Person doc  : found. FullName=[" & _
              CStr(personDoc.GetItemValue("FullName")(0)) & "]" & Chr(10)
        dbg = dbg & "              ShortName=[" & CStr(personDoc.GetItemValue("ShortName")(0)) & "]" & Chr(10)
    End If

    '-- 7. Rotate history — prepend new entry, trim to MAX_HISTORY ----------
    Dim existingItems As Variant
    existingItems = personDoc.GetItemValue("LoginHistory")

    Dim newHistory() As String
    ReDim newHistory(MAX_HISTORY - 1)
    newHistory(0) = entry

    Dim i As Integer
    Dim filled As Integer
    filled = 1
    For i = 0 To UBound(existingItems)
        If filled >= MAX_HISTORY Then Exit For
        Dim existingVal As String
        existingVal = CStr(existingItems(i))
        If existingVal <> "" Then
            newHistory(filled) = existingVal
            filled = filled + 1
        End If
    Next i
    ReDim Preserve newHistory(filled - 1)

    If DEBUG_MODE Then
        dbg = dbg & "History     : previous entries=" & (filled - 1) & Chr(10)
        dbg = dbg & "              new entry=[" & entry & "]" & Chr(10)
    End If

    '-- 8. Write fields back to Person document ----------------------------
    Call personDoc.ReplaceItemValue("LoginHistory", newHistory)
    Call personDoc.ReplaceItemValue("LoginHistoryUpdated", Now())

    Dim saveOk As Boolean
    saveOk = personDoc.Save(True, False)

    If DEBUG_MODE Then
        Dim saveResult As String
        If saveOk Then
            saveResult = "SUCCESS"
        Else
            saveResult = "FAILED — check ACL and signer rights on names.nsf"
        End If
        dbg = dbg & "Save result : " & saveResult & Chr(10)
        dbg = dbg & "---" & Chr(10)
    End If

    '-- 9. Optional: send email notification --------------------------------
    If SEND_EMAIL_ON_NEW_ATTEMPT Then
        Call SendNotificationEmail(session, namesDb, personDoc, entry, ipAddress)
    End If

    '-- 10. Clean up --------------------------------------------------------
    If Not (usersView Is Nothing) Then Call usersView.Recycle()
    Call personDoc.Recycle()
    Call namesDb.Recycle()

    If DEBUG_MODE Then
        dbg = dbg & "OK" & Chr(10)
        Call RespondDebug(dbg)
    Else
        Call RespondOk()
    End If
    Exit Sub

ErrorHandler:
    Dim errMsg As String
    errMsg = "ERROR " & Err & " at line " & Erl & ": " & Error$
    If DEBUG_MODE Then
        dbg = dbg & Chr(10) & errMsg & Chr(10)
        Call RespondDebug(dbg)
    Else
        Print "Content-type: text/plain"
        Print ""
        Print errMsg
    End If
    Resume Next
End Sub

'===========================================================================
' RespondOk  — minimal HTTP 200 response body (production)
'===========================================================================
Sub RespondOk()
    Print "Content-type: text/plain"
    Print ""
    Print "OK"
End Sub

'===========================================================================
' RespondDebug  — returns the full debug log as plain text
'===========================================================================
Sub RespondDebug(trace As String)
    Print "Content-type: text/plain"
    Print ""
    Print trace
End Sub

'===========================================================================
' RespondError — returns an error message as plain text
'===========================================================================
Sub RespondError(msg As String, trace As String)
    Print "Content-type: text/plain"
    Print ""
    If DEBUG_MODE Then
        Print trace & "FATAL: " & msg
    Else
        Print "ERROR: " & msg
    End If
End Sub

'===========================================================================
' GetField  — safely retrieves a single text value from a CGI / POST doc
'===========================================================================
Function GetField(doc As NotesDocument, fieldName As String) As String
    On Error Resume Next
    Dim fldVal As Variant
    fldVal = doc.GetItemValue(fieldName)
    If IsArray(fldVal) Then
        If UBound(fldVal) >= 0 Then
            GetField = CStr(fldVal(0))
        Else
            GetField = ""
        End If
    Else
        GetField = CStr(fldVal)
    End If
    On Error GoTo 0
End Function

'===========================================================================
' SendNotificationEmail
' Sends a memo to the user with details of the new login attempt.
' Only called if SEND_EMAIL_ON_NEW_ATTEMPT = True.
'===========================================================================
Sub SendNotificationEmail(session As NotesSession, namesDb As NotesDatabase, _
                          personDoc As NotesDocument, entry As String, ip As String)
    On Error GoTo EmailError

    Dim mailDb As NotesDatabase
    Dim mailFile As String
    mailFile = CStr(personDoc.GetItemValue("MailFile")(0))
    Dim mailServer As String
    mailServer = CStr(personDoc.GetItemValue("MailServer")(0))

    If mailFile = "" Then Exit Sub

    Set mailDb = New NotesDatabase(mailServer, mailFile)
    If Not mailDb.IsOpen Then Call mailDb.Open(mailServer, mailFile)
    If Not mailDb.IsOpen Then Exit Sub

    Dim memo As NotesDocument
    Set memo = mailDb.CreateDocument()

    Call memo.ReplaceItemValue("Form", "Memo")
    Call memo.ReplaceItemValue("Subject", EMAIL_SUBJECT)

    Dim recipient As String
    recipient = CStr(personDoc.GetItemValue("InternetAddress")(0))
    If recipient = "" Then
        recipient = CStr(personDoc.GetItemValue("FullName")(0))
    End If
    Call memo.ReplaceItemValue("SendTo", recipient)

    Dim parts() As String
    parts = Split(entry, "|")
    Dim body As String
    body = "A new login attempt was recorded for your account." & Chr(10) & Chr(10)
    If UBound(parts) >= 1 Then body = body & "Time      : " & parts(0) & Chr(10)
    If UBound(parts) >= 1 Then body = body & "IP Address: " & parts(1) & Chr(10)
    If UBound(parts) >= 3 Then body = body & "Browser   : " & parts(3) & Chr(10)
    If UBound(parts) >= 4 Then body = body & "Platform  : " & parts(4) & Chr(10)
    If UBound(parts) >= 5 Then body = body & "Timezone  : " & parts(5) & Chr(10)
    body = body & Chr(10) & "If this was not you, please contact IT Support immediately."

    Dim bodyItem As NotesRichTextItem
    Set bodyItem = memo.CreateRichTextItem("Body")
    Call bodyItem.AppendText(body)

    Call memo.Send(False)
    Call mailDb.Recycle()
    Exit Sub

EmailError:
    ' Email failure is non-fatal — log and continue
    Print "Email notification failed: " & Err & " " & Error$
    Resume Next
End Sub
